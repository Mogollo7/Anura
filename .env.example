# PostgreSQL
POSTGRES_USER=anura_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=anura
DATABASE_URL=postgresql://anura_user:change_me@postgres:5432/anura

# JWT
JWT_SECRET=change_me_secret

# MinIO (objetos S3-compatible; bucket creado por minio-init en compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=anura-images
# MINIO_USE_SSL=true

# Redis
REDIS_URL=redis://redis:6379

# Frontend URL (para Google OAuth callback)
FRONTEND_URL=https://anura.juanlabs.me

# Service URLs (for Gateway/Proxy)
AUTH_SERVICE_URL=http://auth-service:3001
OBSERVATION_SERVICE_URL=http://observation-service:3002
AI_SERVICE_URL=http://ai-service:8000
GEO_SERVICE_URL=http://geo-service:3003
THUMBNAIL_SERVICE_URL=http://thumbnail-service:3004
EXPLORER_SERVICE_URL=http://explorer-service:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006
VALIDATION_SERVICE_URL=http://validation-service:3007

# Node env
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://anura.juanlabs.me/api/auth/google/callback

